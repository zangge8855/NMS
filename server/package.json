{
  "name": "nms-server",
  "version": "2.0.0",
  "description": "Node Management System backend",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "start:prod": "node scripts/start_production.js",
    "dev": "node --watch index.js",
    "db:backfill": "node scripts/backfill_to_db.js",
    "review:fake-panel": "node scripts/review_fake_panel.js",
    "review:seed": "node scripts/seed_review_harness.js",
    "review:server": "PORT=3101 DATA_DIR=/tmp/nms-review-harness ALLOW_PRIVATE_SERVER_URL=true SERVE_CLIENT=true node index.js",
    "test": "node --test --test-isolation=none"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "form-data": "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.13.1",
    "ws": "^8.19.0"
  },
  "overrides": {
    "qs": "^6.15.0"
  }
}
